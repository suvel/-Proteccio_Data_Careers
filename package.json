{
  "name": "proteccio-interview-submission",
  "version": "1.0.0",
  "private": true,
  "description": "CSV/XLS to JSON parsing utility",
  "scripts": {
    "build": "tsc && npm --prefix client install && npm --prefix client run build",
    "start": "node dist/server.js",
    "dev": "ts-node server.ts",
    "test": "jest",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\" --ignore-path .prettierignore"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.8",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "multer": "^2.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.17.9",
    "@types/supertest": "^7.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.9.6",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
